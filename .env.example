# ═════════════════════════════════════════════════════════════════════════════
# KAVOX - FULL-STACK ECOMMERCE PLATFORM
# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ═════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
DEBUG=true
SERVICE_AUTH_KEY=your-service-to-service-auth-key-keep-it-secret

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/kavox
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_REPLICASET=

# ──────────────────────────────────────────────────────────────────────────────
# REDIS (Optional - for caching)
# ──────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH (For search service)
# ──────────────────────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-key-minimum-32-characters
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ──────────────────────────────────────────────────────────────────────────────
# RAZORPAY PAYMENT GATEWAY
# ──────────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxx
PLATFORM_COMMISSION=5

# ──────────────────────────────────────────────────────────────────────────────
# QIKINK PRINT-ON-DEMAND API
# ──────────────────────────────────────────────────────────────────────────────
QIKINK_API_URL=https://api.qikink.com
QIKINK_API_KEY=your-qikink-api-key
QIKINK_API_SECRET=your-qikink-api-secret
QIKINK_WEBHOOK_URL=https://yoursite.com/api/qikink/webhook

# ──────────────────────────────────────────────────────────────────────────────
# TWILIO SMS (For OTP)
# ──────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
OTP_EXPIRY=600

# ──────────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE (Nodemailer)
# ──────────────────────────────────────────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@kavox.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ──────────────────────────────────────────────────────────────────────────────
# CLOUDINARY (Image Storage)
# ──────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ──────────────────────────────────────────────────────────────────────────────
# MICROSERVICE URLS
# ──────────────────────────────────────────────────────────────────────────────
GATEWAY_URL=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3004
QIKINK_SERVICE_URL=http://localhost:3005
SEARCH_SERVICE_URL=http://localhost:3006
RECOMMENDATION_SERVICE_URL=http://localhost:3007
SELLER_SERVICE_URL=http://localhost:3008
ADMIN_SERVICE_URL=http://localhost:3009

# ──────────────────────────────────────────────────────────────────────────────
# MICROSERVICE PORTS
# ──────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
QIKINK_SERVICE_PORT=3005
SEARCH_SERVICE_PORT=3006
RECOMMENDATION_SERVICE_PORT=3007
SELLER_SERVICE_PORT=3008
ADMIN_SERVICE_PORT=3009

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ──────────────────────────────────────────────────────────────────────────────
# AWS (Optional - for S3 storage)
# ──────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ──────────────────────────────────────────────────────────────────────────────
# STRIPE (Optional - alternative payment)
# ──────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# LOGGING & MONITORING
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ──────────────────────────────────────────────────────────────────────────────
# BUSINESS CONFIG
# ──────────────────────────────────────────────────────────────────────────────
BUSINESS_NAME=Kavox
BUSINESS_URL=https://kavox.com
BUSINESS_EMAIL=support@kavox.com
BUSINESS_PHONE=+1234567890
SELLER_COMMISSION=5
ADMIN_EMAIL=admin@kavox.com
