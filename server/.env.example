# KAVOX Platform - Root Environment
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/kavox
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ACCESS_SECRET=kavox_access_secret_min_32_chars_change_this
JWT_REFRESH_SECRET=kavox_refresh_secret_min_32_chars_change_this
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
ALLOWED_ORIGINS=http://localhost:3000
GATEWAY_SECRET=kavox_gateway_secret_change_this

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=KAVOX
EMAIL_FROM_ADDRESS=noreply@kavox.com

# Razorpay (admin account - all payments go here)
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Cloudinary (for product images + design uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Qikink Print-on-Demand
QIKINK_BASE_URL=https://api.qikink.com
QIKINK_API_KEY=your_qikink_api_key

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Qikink Webhook
QIKINK_WEBHOOK_SECRET=your_qikink_webhook_secret
QIKINK_POLL_INTERVAL_MS=1800000      # 30 minutes (milliseconds)
