# ============================================================
# KAVOX Auth Service - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=5001
SERVICE_NAME=auth-service

# MongoDB
MONGO_URI=mongodb://localhost:27017/kavox_auth
MONGO_URI_TEST=mongodb://localhost:27017/kavox_auth_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_change_this
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
JWT_ISSUER=kavox-platform

# OTP / Email Verification
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
MAX_OTP_ATTEMPTS=3

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=KAVOX
EMAIL_FROM_ADDRESS=noreply@kavox.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# API Gateway secret (for inter-service auth)
GATEWAY_SECRET=kavox_gateway_secret_key_change_this_in_production

# bcrypt rounds
BCRYPT_ROUNDS=12

# Cookie
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
